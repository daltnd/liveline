{
  "name": "liveline",
  "version": "0.1.0",
  "type": "module",
  "description": "Real-time animated charts for Svelte — line, candlestick, and multi-series modes",
  "keywords": [
    "svelte",
    "chart",
    "canvas",
    "real-time",
    "animation",
    "line-chart",
    "candlestick",
    "ohlc",
    "multi-series",
    "multi-line"
  ],
  "license": "MIT",
  "author": "Benji Taylor",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/benjitaylor/liveline.git"
  },
  "homepage": "https://github.com/benjitaylor/liveline#readme",
  "bugs": "https://github.com/benjitaylor/liveline/issues",
  "sideEffects": [
    "**/*.css"
  ],
  "svelte": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "svelte": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "!dist/**/*.test.*",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "build": "svelte-package -i src -o dist",
    "dev": "svelte-package -i src -o dist -w",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "svelte-check --tsconfig ./tsconfig.json",
    "prepare": "npm run build"
  },
  "peerDependencies": {
    "svelte": "^5.29.0"
  },
  "devDependencies": {
    "@sveltejs/package": "^2.3.7",
    "svelte": "^5.0.0",
    "svelte-check": "^4.1.0",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  }
}
